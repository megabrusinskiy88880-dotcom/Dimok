# Скопируй в .env для локального запуска. В Railway задай эти переменные в разделе Variables.

# Секретный путь до админки. Придумай что-то уникальное и никому не говори.
# Пример: admin-9f2k7x-mine
ADMIN_PATH=admin-portal-7f3k9x2m

# Пароль для входа в админку.
ADMIN_PASSWORD=change-me-please

# Секрет для подписи сессионных cookie. Любая длинная случайная строка.
SESSION_SECRET=insecure-dev-secret-change-in-railway

# Порт (Railway подставит автоматически, локально можно оставить)
PORT=3000

NODE_ENV=production
